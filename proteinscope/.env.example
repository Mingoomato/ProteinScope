# NCBI E-utilities API key (optional, increases rate limit from 3 to 10 req/sec)
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here

# OMIM API key (required for disease/deficiency data)
# Register at: https://www.omim.org/api
OMIM_API_KEY=your_omim_api_key_here

# BRENDA enzyme database credentials (required for temperature/pH optima)
# Register at: https://www.brenda-enzymes.org/register.php
BRENDA_USERNAME=your_email@example.com
BRENDA_PASSWORD=your_brenda_password_here

# ── Pathway databases ────────────────────────────────────────────────────────

# PharmGKB API key (required for drug interactions, PGx variants, FDA labels)
# Register via email request at: https://www.pharmgkb.org/page/contacts
# (Granted quickly for academic use; without it DGIdb + ChEMBL still provide drug data)
PHARMGKB_API_KEY=your_pharmgkb_key_here

# BioCyc / MetaCyc credentials (required for detailed metabolic enzyme roles)
# Register at: https://biocyc.org/PerlCyc/create_account.shtml
BIOCYC_USERNAME=your_email@example.com
BIOCYC_PASSWORD=your_biocyc_password_here

# Gemini API key (for future natural language query layer)
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# No API key required for:
#   KEGG, Reactome, STRING, DGIdb, ChEMBL — all public REST/GraphQL APIs
